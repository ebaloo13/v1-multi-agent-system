{
  "name": "claude-agent-b2b-lab",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "preaudit:demo": "tsx scripts/demo/run-preaudit-demo.ts",
    "preaudit:live": "node -e \"const { spawnSync } = require('node:child_process'); const originalArgv = process.env.npm_config_argv || ''; const explicitlyRequested = originalArgv.includes('preaudit:live'); const args = process.argv.slice(1); const hasUrl = args.some((arg) => arg === '--url' || arg.startsWith('--url=')); if (!explicitlyRequested && !hasUrl) process.exit(0); const result = spawnSync('tsx', ['scripts/live/run-preaudit-live.ts', ...args], { stdio: 'inherit', shell: process.platform === 'win32' }); process.exit(result.status ?? 1);\" --",
    "preaudit:report": "tsx scripts/live/run-preaudit-report.ts",
    "audit:demo": "tsx scripts/demo/run-audit-demo.ts",
    "audit:live": "tsx scripts/live/run-audit-live.ts",
    "collections:demo": "tsx scripts/demo/run-collections-demo.ts",
    "sales:demo": "tsx scripts/demo/run-sales-demo.ts",
    "operations:demo": "tsx scripts/demo/run-operations-demo.ts",
    "orchestrator:demo": "tsx scripts/demo/run-orchestrator-demo.ts",
    "preaudit:batch": "tsx scripts/batch/run-preaudit-batch.ts",
    "audit:batch": "tsx scripts/batch/run-audit-batch.ts",
    "sales:batch": "tsx scripts/batch/run-sales-batch.ts",
    "operations:batch": "tsx scripts/batch/run-operations-batch.ts",
    "collections:batch": "tsx scripts/batch/run-collections-batch.ts",
    "orchestrator:batch": "tsx scripts/batch/run-orchestrator-batch.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test src/collections/validateOutput.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@mariozechner/pi-ai": "^0.66.1",
    "dotenv": "^16.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0"
  }
}
